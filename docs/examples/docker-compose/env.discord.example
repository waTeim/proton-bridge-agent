# Docker Compose environment with Discord notifications enabled.
# Copy this file to .env and fill in your values.

# ── Image references ─────────────────────────────────────────────────────────
BRIDGE_IMAGE=your-registry/proton-bridge:latest
SIDECAR_IMAGE=your-registry/proton-bridge-sidecar:latest

# ── Host port mapping ────────────────────────────────────────────────────────
SMTP_PORT=1025
IMAP_PORT=1143
SIDECAR_PORT=4209

# ── Discord notifications ────────────────────────────────────────────────────
# Point to your discord.yaml file. The sidecar reads bot_token and channel_id
# from this file and posts email notifications to the configured Discord channel.
DISCORD_CONFIG=./discord.yaml
