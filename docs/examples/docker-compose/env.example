# Docker Compose environment for proton-bridge-agent
# Copy this file to .env and fill in your values.
#
# If you use `make compose-up`, BRIDGE_IMAGE and SIDECAR_IMAGE are injected
# automatically from config.json — you only need .env for port overrides or
# Discord configuration.

# ── Image references ─────────────────────────────────────────────────────────
# Required if running `docker compose up` directly (without Make).
# Set these to your registry image refs after `make push` / `make sidecar-push`.
BRIDGE_IMAGE=your-registry/proton-bridge:latest
SIDECAR_IMAGE=your-registry/proton-bridge-sidecar:latest

# ── Host port mapping ────────────────────────────────────────────────────────
# Defaults match the Kubernetes Service ports. Change if you have conflicts.
# On a VPS, bind to 127.0.0.1 to restrict access (e.g. 127.0.0.1:1025:25).
SMTP_PORT=1025
IMAP_PORT=1143
SIDECAR_PORT=4209

# ── Discord notifications (optional) ────────────────────────────────────────
# To enable Discord notifications:
#   1. Copy docs/examples/docker-compose/discord.yaml.example to discord.yaml
#   2. Fill in bot_token and channel_id
#   3. Uncomment the line below
# DISCORD_CONFIG=./discord.yaml
